{
  "name": "financeflow",
  "version": "1.0.0",
  "description": "FinanceFlow - Sistema Financeiro Automático",
  "main": "electron.cjs",
  "scripts": {
    "vite": "vite",
    "dev": "concurrently \"npm run vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.financeflow.app",
    "productName": "FinanceFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FinanceFlow"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "lucide-react": "^0.469.0",
    "tailwindcss": "^4.3.0",
    "vite": "^6.3.5",
    "wait-on": "^9.0.10"
  }
}
